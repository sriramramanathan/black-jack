{
  "compilerOptions": {
    "target": "ES2020",
    // DOM + DOM.Iterable gives us browser APIs (WebSocket, fetch, etc.)
    // This is different from the worker tsconfig which has NO dom types
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "paths": {
      "@blackjack/game-logic": ["../packages/game-logic/src/index.ts"],
      "@blackjack/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
